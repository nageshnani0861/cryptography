# 17. DES Key Schedule Design

# Example 64-bit key
key = "1010101111001101111001101010101111001101111001101010101111001101"

# PC-1 table
pc1 = [57,49,41,33,25,17,9,
       1,58,50,42,34,26,18,
       10,2,59,51,43,35,27,
       19,11,3,60,52,44,36,
       63,55,47,39,31,23,15,
       7,62,54,46,38,30,22,
       14,6,61,53,45,37,29,
       21,13,5,28,20,12,4]

# Apply PC-1
perm = "".join(key[i-1] for i in pc1)

left = perm[:28]
right = perm[28:]

print("C0 =", left)
print("D0 =", right)
